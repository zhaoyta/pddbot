# 复制为 .env 后填实际值

# ===== DeepSeek =====
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ===== 自动客服行为 =====
# 收到新消息后随机延迟范围（秒）
REPLY_DELAY_MIN=1.5
REPLY_DELAY_MAX=3.5

# 单 uid 每分钟最多自动回复条数
RATE_LIMIT_PER_UID_PER_MIN=3

# 全店每分钟最多自动回复条数
RATE_LIMIT_GLOBAL_PER_MIN=30

# 夜间静默时段（24 小时制，留空表示不静默）
NIGHT_QUIET_START=23:00
NIGHT_QUIET_END=08:00

# 转人工告警 webhook（钉钉/飞书/企业微信，留空则只打日志）
ESCALATE_WEBHOOK=

# 白名单调试模式：填了 uid（逗号分隔）则只对这些 uid 自动回复；空=全量
WHITELIST_UIDS=
