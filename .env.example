# 复制为 .env 后填实际值

# ===== 总开关 =====
# false 时 bot 进入待机：只监听不发送、不核销，便于紧急止损
BOT_ENABLED=true

# true 时 LLM 正常生成回复但不点击发送、不执行核销，
# 所有动作只写入 action_log 表供人工审核
DRY_RUN=false

# ===== DeepSeek =====
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ===== 自动客服行为（预留；主循环尚未启用）=====
# 下列键会写入 SQLite settings（rate.*），但当前 bot 流水线不会据此延迟或限频。
# 收到新消息后随机延迟范围（秒）— 未接入 _process_chat_msg
REPLY_DELAY_MIN=1.5
REPLY_DELAY_MAX=3.5

# 单 uid / 全店每分钟最多自动回复条数 — 未接入统计与拦截
RATE_LIMIT_PER_UID_PER_MIN=3
RATE_LIMIT_GLOBAL_PER_MIN=30

# 转人工告警 webhook（钉钉/飞书/企业微信，留空则只打日志）
ESCALATE_WEBHOOK=

# 白名单调试模式：填了 uid（逗号分隔）则只对这些 uid 自动回复；空=全量
WHITELIST_UIDS=
